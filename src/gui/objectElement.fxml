<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #21222c; -fx-border-color: #44475a; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 50; -fx-cursor: hand;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ItemBarangController">
  <Label fx:id="idLabel" style="-fx-text-fill: #f8f8f2; -fx-font-size: 12px; -fx-font-weight: bold; -fx-min-width: 60; -fx-pref-width: 60; -fx-alignment: CENTER_LEFT;" text="ID"/>
  <Label fx:id="namaLabel" style="-fx-text-fill: #f8f8f2; -fx-font-size: 13px; -fx-font-weight: bold; -fx-min-width: 150;" text="Nama Barang" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
  <Label fx:id="kategoriLabel" style="-fx-text-fill: #f8f8f2; -fx-font-size: 13px; -fx-min-width: 120;" text="Kategori" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
  <Label fx:id="stokLabel" style="-fx-background-color: #1a3a2a; -fx-text-fill: #50fa7b; -fx-font-size: 11px; -fx-padding: 3 8; -fx-background-radius: 4; -fx-min-width: 55; -fx-alignment: CENTER;" text="0 pcs"/>
</HBox>
