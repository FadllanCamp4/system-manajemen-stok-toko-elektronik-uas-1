<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="580" prefWidth="900" style="-fx-background-color: #282a36;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AddController">

    <!-- ===== SIDEBAR KIRI ===== -->
    <left>
        <VBox prefWidth="220" style="-fx-background-color: #21222c; -fx-border-color: #44475a; -fx-border-width: 0 1 0 0;">

            <!-- Logo -->
            <VBox style="-fx-padding: 20 16 12 16; -fx-border-color: #44475a; -fx-border-width: 0 0 1 0;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-background-color: #bd93f9; -fx-text-fill: #21222c; -fx-font-size: 14px; -fx-padding: 4 6; -fx-background-radius: 6;" text="◆" />
                    <Label style="-fx-text-fill: #f8f8f2; -fx-font-size: 14px; -fx-font-weight: bold;" text="kelompok 7" />
                </HBox>
            </VBox>

            <!-- Nav Items -->
            <VBox prefHeight="358.0" prefWidth="219.0" style="-fx-padding: 12 8 8 8;" VBox.vgrow="ALWAYS">

                <!-- Section: main -->
                <Label style="-fx-text-fill: #6272a4; -fx-font-size: 10px; -fx-padding: 8 8 4 8;" text="MAIN" />

                <Button fx:id="btnDashboard" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showDashboard" style="-fx-background-color: transparent; -fx-text-fill: #6272a4; -fx-font-size: 13px; -fx-padding: 8 10; -fx-background-radius: 6; -fx-border-width: 0; -fx-cursor: hand;" text="  ■  Dashboard" />

                <!-- Section: kelola -->
                <Label style="-fx-text-fill: #6272a4; -fx-font-size: 10px; -fx-padding: 12 8 4 8;" text="KELOLA" />

                <Button fx:id="btnAdd" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showAdd" style="-fx-background-color: #282a36; -fx-text-fill: #bd93f9; -fx-font-size: 13px; -fx-padding: 8 10; -fx-background-radius: 6; -fx-border-width: 0;" text="  Tambah data" />
                <Button fx:id="btnDelete" alignment="CENTER_LEFT" layoutX="18.0" layoutY="149.0" maxWidth="Infinity" onAction="#showDelete" style="-fx-background-color: transparent; -fx-text-fill: #6272a4; -fx-font-size: 13px; -fx-padding: 8 10; -fx-background-radius: 6; -fx-border-width: 0; -fx-cursor: hand;" text="  Hapus data" />
            </VBox>

            <!-- Footer User -->
            <VBox style="-fx-padding: 12 8; -fx-border-color: #44475a; -fx-border-width: 1 0 0 0;" />

        </VBox>
    </left>

    <!-- ===== KONTEN UTAMA ===== -->
    <center>
        <BorderPane style="-fx-background-color: #282a36;">

            <!-- Topbar -->
            <top>
                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 14 20; -fx-border-color: #44475a; -fx-border-width: 0 0 1 0; -fx-background-color: #282a36;">
                    <Label fx:id="pageTitle" style="-fx-text-fill: #f8f8f2; -fx-font-size: 15px; -fx-font-weight: bold;" text="Tambah Barang" />
                </HBox>
            </top>

            <!-- Area Konten -->
            <center>
                <StackPane fx:id="contentArea" style="-fx-background-color: #282a36; -fx-padding: 20;">
               <children>
                  <HBox prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: #21222c;">
                     <children>
                        <VBox alignment="TOP_CENTER" prefHeight="490.0" prefWidth="261.0" style="-fx-border-color: #44475a;">
                           <children>
                              <TextField fx:id="namaBarangInput" maxHeight="1.7976931348623157E308" maxWidth="-Infinity" minWidth="-Infinity" prefHeight="27.0" prefWidth="206.0" promptText="nama barang">
                                 <VBox.margin>
                                    <Insets bottom="20.0" top="20.0" />
                                 </VBox.margin>
                              </TextField>
                              <TextField fx:id="jumlahBarangInput" layoutX="38.0" layoutY="31.0" maxHeight="1.7976931348623157E308" maxWidth="-Infinity" minWidth="-Infinity" prefHeight="27.0" prefWidth="206.0" promptText="stok barang">
                                 <VBox.margin>
                                    <Insets bottom="20.0" />
                                 </VBox.margin>
                              </TextField>
                              <ComboBox fx:id="enumKategoriInput" editable="true" prefHeight="27.0" prefWidth="206.0" promptText="kategori barang">
                                 <VBox.margin>
                                    <Insets bottom="20.0" />
                                 </VBox.margin>
                              </ComboBox>
                              <Button mnemonicParsing="false" onAction="#submitBarang" style="-fx-translate-y: 90;" text="submit" />
                           </children>
                        </VBox>
                        <VBox alignment="TOP_CENTER" prefHeight="490.0" prefWidth="561.0" HBox.hgrow="ALWAYS">
                           <children>
                              <TableView fx:id="tableBarang" prefHeight="490.0" prefWidth="561.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-table-cell-border-color: #383a4a; -fx-control-inner-background: #21222c; -fx-control-inner-background-alt: #252636;" VBox.vgrow="ALWAYS">
                                <columns>
                                  <TableColumn prefWidth="50.0" text="ID">
                                      <cellValueFactory>
                                          <PropertyValueFactory property="id" />
                                      </cellValueFactory>
                                  </TableColumn>
                                  <TableColumn prefWidth="150.0" text="Nama">
                                      <cellValueFactory>
                                          <PropertyValueFactory property="nama" />
                                      </cellValueFactory>
                                  </TableColumn>
                                  <TableColumn prefWidth="100.0" text="Kategori">
                                      <cellValueFactory>
                                          <PropertyValueFactory property="kategori" />
                                      </cellValueFactory>
                                  </TableColumn>
                                  <TableColumn prefWidth="100.0" text="Stok">
                                      <cellValueFactory>
                                          <PropertyValueFactory property="stok" />
                                      </cellValueFactory>
                                  </TableColumn>
                                </columns>
                              </TableView>
                           </children>
                           <opaqueInsets>
                               <Insets />
                           </opaqueInsets>
                           <HBox.margin>
                               <Insets left="10.0" />
                           </HBox.margin>
                        </VBox>
                     </children>
                  </HBox>
               </children>

                </StackPane>
            </center>

        </BorderPane>
    </center>

</BorderPane>
